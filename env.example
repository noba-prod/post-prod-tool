# Supabase Configuration (required for authentication)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site Configuration
SITE_URL=http://localhost:3000

# Resend (invitation emails when publishing a collection)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=
# Sender address, e.g. onboarding@yourdomain.com or onboarding@resend.dev for development
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron (external cron e.g. cron-job.org calling /api/cron/notifications)
# Use a long random string; same value must be sent as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Node Environment (automatically set by Next.js)
# NODE_ENV=development

# Test commit on dev branch
