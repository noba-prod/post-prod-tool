# Supabase Configuration (Optional - only needed if NOT using mock auth)
# Leave empty or use placeholder values if using mock authentication
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Authentication
# Set to "false" to disable mock authentication (default: enabled)
# When mock auth is enabled, Supabase variables are not required
NEXT_PUBLIC_USE_MOCK_AUTH=true

# Site Configuration
SITE_URL=http://localhost:3000

# Resend (invitation emails when publishing a collection)
# Get API key from https://resend.com/api-keys
RESEND_API_KEY=
# Sender address, e.g. onboarding@yourdomain.com or onboarding@resend.dev for development
RESEND_FROM_EMAIL=onboarding@resend.dev

# Node Environment (automatically set by Next.js)
# NODE_ENV=development

# Test commit on dev branch
